# Gemini
GOOGLE_GENAI_USE_VERTEXAI=FALSE
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Dynatrace MCP
DT_ENVIRONMENT=https://YOUR_ENV.apps.dynatrace.com
DT_PLATFORM_TOKEN=
DT_API_TOKEN=
DT_MCP_SERVER_VERSION=0.13.0
DT_MCP_DISABLE_TELEMETRY=true
DT_GRAIL_QUERY_BUDGET_GB=5

# Dynatrace OTLP ingest
DT_OTLP_ENDPOINT=https://YOUR_ENV_ID.live.dynatrace.com/api/v2/otlp
DT_OTLP_TOKEN=

# Local service URLs
AEGIS_DEMO_APP_URL=http://127.0.0.1:8001
AEGIS_DASHBOARD_URL=http://127.0.0.1:8000

# Actions
GITHUB_TOKEN=
GITHUB_REPO=owner/aegis-demo
GITHUB_BASE_BRANCH=main
SLACK_WEBHOOK=

# Tuning
SLO_TARGET=0.995
BURN_ABORT=10
BURN_WINDOW_SECONDS=90
LATENCY_THRESHOLD_MS=500
AEGIS_APPROVAL_TIMEOUT_S=900
AEGIS_MCP_TIMEOUT_SECONDS=90
AEGIS_REPORTS_DIR=runtime_artifacts
STORE_BASE_LATENCY_MS=40
LOADGEN_RPS=20
